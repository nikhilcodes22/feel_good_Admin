# FeelGood Connect — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# Supabase (used for legacy dashboard/assets routes only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# API Backend (custom Node/Express backend)
# Leave blank to use Vite proxy in local dev (proxy forwards /api/* to api.feelgoodapp.net)
# Set to full URL for production builds deployed to S3/CloudFront:
#   VITE_API_URL=https://api.feelgoodapp.net
VITE_API_URL=
